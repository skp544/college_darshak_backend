generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  STUDENT
  MENTOR
}

enum IdentifierType {
  EMAIL
  PHONE
}

enum CollegeType {
  PRIVATE
  GOVERNMENT
  SEMIGOVERNMENT
}

enum EducationLevel {
  SECONDARY
  SENIOR_SECONDARY
  UNDERGRADUATE
  POSTGRADUATE
}

//////////////////////////////////////////////////////
// USER MODEL
//////////////////////////////////////////////////////

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  phoneNo        String          @unique
  password       String?
  role           Role            @default(STUDENT)
  createdAt      DateTime        @default(now())
  mentorDetails  MentorDetails?
  studentDetails StudentDetails?
}

//////////////////////////////////////////////////////
// OTP MODEL (NO FK — PRE-REGISTRATION)
//////////////////////////////////////////////////////

// STUDENT DETAILS

model StudentDetails {
  id             String         @id @default(uuid())
  userId         String         @unique
  name           String
  dob            DateTime
  educationLevel EducationLevel

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetCourses  StudentTargetCourses[]
  targetColleges StudentTargetColleges[]
}

model StudentTargetCourses {
  id        String @id @default(uuid())
  studentId String
  course    String

  student StudentDetails @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model StudentTargetColleges {
  id        String @id @default(uuid())
  studentId String
  collegeId String

  student StudentDetails @relation(fields: [studentId], references: [id], onDelete: Cascade)
  college College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model OtpSchema {
  id             String         @id @default(uuid())
  identifier     String
  identifierType IdentifierType
  otp            String
  createdAt      DateTime       @default(now())
  expiresAt      DateTime

  @@index([identifier])
}

//////////////////////////////////////////////////////
// MENTOR DETAILS (1:1 WITH USER)
//////////////////////////////////////////////////////

model MentorDetails {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  dob       DateTime
  biography String
  city      String
  state     String
  location  String
  verified  Boolean  @default(false)

  collegeId String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college College? @relation(fields: [collegeId], references: [id], onDelete: Restrict)

  academicDetails AcademicDetails?
  languages       MentorLanguages[]
}

//////////////////////////////////////////////////////
// ACADEMIC DETAILS (1:1 WITH MENTOR)
//////////////////////////////////////////////////////

model AcademicDetails {
  id                String  @id @default(uuid())
  mentorId          String  @unique
  university        String
  course            String
  specialization    String
  currentYear       Int
  courseType        String
  courseDuration    String
  currentCGPA       Float
  lastSemAttendance Float
  placed            Boolean
  companyName       String?
  hostelAvail       Boolean
  marksheetUrl      String
  profilePhoto      String

  mentor MentorDetails @relation(fields: [mentorId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// COLLEGE (1:N WITH MENTORS)
//////////////////////////////////////////////////////

model College {
  id            String      @id @default(uuid())
  collegeName   String
  description   String
  established   String
  type          CollegeType
  location      String
  state         String
  accreditation String
  phoneNo       String
  website       String

  mentors               MentorDetails[]
  courses               CollegeCourses[]
  studentTargetColleges StudentTargetColleges[]
}

//////////////////////////////////////////////////////
// MENTOR LANGUAGES (1:N)
//////////////////////////////////////////////////////

model MentorLanguages {
  id       String @id @default(uuid())
  mentorId String
  language String

  mentor MentorDetails @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
}

//////////////////////////////////////////////////////
// COLLEGE COURSES (1:N)
//////////////////////////////////////////////////////

model CollegeCourses {
  id         String @id @default(uuid())
  collegeId  String
  courseName String

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}
