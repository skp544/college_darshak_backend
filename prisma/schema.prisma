//////////////////////////////////////////////////////
// ACADEMIC DETAILS (1:1 WITH MENTOR)
//////////////////////////////////////////////////////

model AcademicDetails {
  id                String  @id @default(uuid())
  mentorId          String  @unique
  university        String
  course            String
  specialization    String
  currentYear       Int
  courseType        String
  courseDuration    String
  currentCGPA       Float
  lastSemAttendance Float
  placed            Boolean
  companyName       String?
  hostelAvail       Boolean
  marksheetUrl      String
  profilePhotoUrl   String
  studentIdCardUrl  String

  // mentor MentorProfile  @relation(fields: [mentorId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// COLLEGE (1:N WITH MENTORS)
//////////////////////////////////////////////////////

model College {
  id            String           @id @default(uuid())
  collegeName   String
  description   String
  established   String
  type          CollegeType
  location      String
  state         String
  accreditation String
  phoneNo       String
  website       String
  featured      Boolean          @default(false)
  // mentors               MentorDetails[]
  courses       CollegeCourses[]
  // studentTargetColleges StudentTargetColleges[]
}

//////////////////////////////////////////////////////
// MENTOR LANGUAGES (1:N)
//////////////////////////////////////////////////////

model MentorLanguages {
  id       String @id @default(uuid())
  mentorId String
  language String

  // mentor MentorDetails @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
}

//////////////////////////////////////////////////////
// COLLEGE COURSES (1:N)
//////////////////////////////////////////////////////

model CollegeCourses {
  id         String @id @default(uuid())
  collegeId  String
  courseName String

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}
