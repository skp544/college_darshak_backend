generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum Role {
  ADMIN
  STUDENT
  MENTOR
}

enum IdentifierType {
  EMAIL
  PHONE
}

enum CollegeType {
  PRIVATE
  GOVERNMENT
  SEMIGOVERNMENT
}

enum EducationLevel {
  SECONDARY
  SENIOR_SECONDARY
  UNDERGRADUATE
  POSTGRADUATE
}

enum AuthProvider {
  EMAIL_PASSWORD
  GOOGLE
  OTP
}

enum MentorStatus {
  PENDING
  APPROVED
  REJECTED
}

//////////////////////////////////////////////////////
// USER MODEL
//////////////////////////////////////////////////////

model User {
  id               String  @id @default(uuid())
  email            String? @unique
  // phoneNo          String?         @unique
  password         String?
  role             Role    @default(STUDENT)
  isVerified       Boolean @default(false)
  profileCompleted Boolean @default(false)

  mentorStatus MentorStatus? @default(PENDING)
  // provider         AuthProvider
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  mentor_profile  MentorProfile?
  student_profile StudentProfile?
  otp             Otp?

  @@index([email])
}

//////////////////////////////////////////////////////
// OTP MODEL (NO FK — PRE-REGISTRATION)
//////////////////////////////////////////////////////
model Otp {
  id        String   @id @default(uuid())
  code      String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// STUDENT DETAILS

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique

  name           String
  date_of_birth  DateTime?
  educationLevel String?
  targetCourses  String?
  targetColleges String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// MENTOR DETAILS (1:1 WITH USER)
//////////////////////////////////////////////////////

model MentorProfile {
  id     String @id @default(uuid())
  userId String @unique

  name        String
  dateOfBirth DateTime?
  state       String?
  city        String?
  phone       String?

  university     String?
  college        String?
  course         String?
  specialization String?
  currentYear    Int?
  cgpa           Float?

  isPlaced    Boolean?
  companyName String?

  languages String[]

  documentsVerified Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

