{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "generated"
  ]
}